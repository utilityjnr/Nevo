#!/bin/sh

# Detect which packages have changes being pushed
UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || true)
if [ -z "$UPSTREAM" ]; then
  CHANGED=$(git diff --name-only HEAD~1 HEAD 2>/dev/null)
else
  CHANGED=$(git diff --name-only "$UPSTREAM" HEAD 2>/dev/null)
fi

FAILED=0

if echo "$CHANGED" | grep -q "^nevo_frontend/"; then
  echo ">>> Frontend changes detected — building..."
  (cd nevo_frontend && npm run build) || FAILED=1
fi

if echo "$CHANGED" | grep -q "^nevo_server/"; then
  echo ">>> Server changes detected — building..."
  (cd nevo_server && npm run build) || FAILED=1
fi

if echo "$CHANGED" | grep -q "^nevo_contract/"; then
  echo ">>> Contract changes detected — building and running tests..."
  (cd nevo_contract && cargo build --release --target wasm32-unknown-unknown && cargo test --lib) || FAILED=1
fi

[ $FAILED -eq 0 ] || exit 1
