# Database connection string (replaces individual DB_* vars when set)
DATABASE_URL=postgresql://user:password@localhost:5432/nevo

# JSON Web Token secret key
JWT_SECRET=your-secret-here

# JWT token expiration duration (e.g. 15m, 1h, 7d)
JWT_EXPIRY=15m

# Stellar network to connect to (testnet or mainnet)
STELLAR_NETWORK=testnet

# Stellar RPC endpoint URL
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Stellar Horizon endpoint URL
HORIZON_URL=https://horizon-testnet.stellar.org

# Contract ID (address) of the deployed smart contract
CONTRACT_ID=your-contract-id-here

# NestJS server port
PORT=3000
